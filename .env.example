ANTHROPIC_API_KEY=your_anthropic_api_key
# Google OAuth
GOOGLE_CLIENT_ID=your_google_client_id
GOOGLE_CLIENT_SECRET=your_google_client_secret
GOOGLE_REDIRECT_URI=https://interrogationclaude-production.up.railway.app/auth/google/callback
# JWT
JWT_SECRET_KEY=generate_with_openssl_rand_hex_32
# Frontend
FRONTEND_URL=https://idea-sharpen.vercel.app
PORT=8000
CORS_ALLOW_ORIGINS=http://localhost:5173,http://127.0.0.1:5173,http://127.0.0.1:8080,http://localhost:8080,https://idea-sharpen.vercel.app
CORS_ALLOW_ORIGIN_REGEX=^https://idea-sharpen(-[a-zA-Z0-9-]+)?\.vercel\.app$
WEBHOOK_ENABLED=false
WEBHOOK_URL=
WEBHOOK_AUTH_HEADER=Authorization
WEBHOOK_AUTH_TOKEN=
WEBHOOK_TIMEOUT_SECONDS=5
DATABASE_PUBLIC_URL="postgresql://${{PGUSER}}:${{POSTGRES_PASSWORD}}@${{RAILWAY_TCP_PROXY_DOMAIN}}:${{RAILWAY_TCP_PROXY_PORT}}/${{PGDATABASE}}"
DATABASE_URL="postgresql://${{PGUSER}}:${{POSTGRES_PASSWORD}}@${{RAILWAY_PRIVATE_DOMAIN}}:5432/${{PGDATABASE}}"
PGDATA="/var/lib/postgresql/data/pgdata"
PGDATABASE="${{POSTGRES_DB}}"
PGHOST="${{RAILWAY_PRIVATE_DOMAIN}}"
PGPASSWORD="${{POSTGRES_PASSWORD}}"
PGPORT="5432"
PGUSER="${{POSTGRES_USER}}"
POSTGRES_DB=
POSTGRES_PASSWORD=
POSTGRES_USER=
RAILWAY_DEPLOYMENT_DRAINING_SECONDS="60"
SSL_CERT_DAYS="820"
